# release.config
# ROCm Installer Build Configuration - Release Builds
#
# This preset is configured for official release builds with all GPU architectures.
# Command-line arguments will override these settings.
#
# Equivalent command line:
#   ./build-runfile-installer.sh \
#       pull=release pulltag=release pullrunid=99999 pullrocmver=7.11.0 \
#       pullamdgpu=release,31.10 \
#       pullpkgextra=amdrocm-blas-test,amdrocm-dnn-test,amdrocm-rand-test,amdrocm-solver-test,amdrocm-sparse-test,amdrocm-rccl-test \
#       pullpkgforce=amdrocm-fft-test \
#       rocm-archs=gfx908,gfx90a,gfx94x,gfx950,gfx110x,gfx1150,gfx1151,gfx120x \
#       amdgpu-mode=all rocm-mode=chroot \
#       mscomp=hybrid buildtag=release buildrunid=99999 buildtaginfo=release-99999

#==============================================================================
# SETUP CONFIGURATION (setup-installer.sh)
#==============================================================================

# Release type: dev, nightly, prerelease, release
# Arg: pull=<type>
PULL_CONFIG_RELEASE_TYPE="release"

# Build tag (required for all builds)
# Arg: pulltag=<tag>
# Note: For release builds, use "release" or the version number
PULL_CONFIG_TAG="release"

# Component build run ID (required for all builds)
# Arg: pullrunid=<runid>
PULL_CONFIG_RUNID="99999"

# ROCm version (e.g., 7.11.0, 7.12.0)
# Arg: pullrocmver=<version>
PULL_CONFIG_ROCM_VER="7.11.0"

# Base package to pull (default: amdrocm-core-sdk)
# Arg: pullpkg=<package>
PULL_CONFIG_PKG="amdrocm-core-sdk"

# Extra packages (array) - comma-separated via pullpkgextra=<packages>
# Arg: pullpkgextra=<pkg1,pkg2,pkg3>
# Test packages for validation and functional testing
PULL_CONFIG_PKG_EXTRA=(amdrocm-blas-test amdrocm-dnn-test amdrocm-rand-test amdrocm-solver-test amdrocm-sparse-test amdrocm-rccl-test)

# Force packages (downloaded without dependency resolution)
# Arg: pullpkgforce=<pkg1,pkg2,pkg3>
# fft-test requires force download due to dependency conflicts
PULL_CONFIG_PKG_FORCE=(amdrocm-fft-test)

# GPU architectures to include (array) - comma-separated via rocm-archs=<archs>
# Arg: rocm-archs=<arch1,arch2,arch3>
# ROCm 7.12+ split CDNA: gfx908 (MI100), gfx90a (MI250X/MI250/MI210)
# For older builds with gfx90x, override with: rocm-archs=gfx90x,gfx94x,gfx950,...
ROCM_GFX_ARCHS=(gfx908 gfx90a gfx94x gfx950 gfx110x gfx1150 gfx1151 gfx120x)

# AMDGPU configuration type and version
# Arg: pullamdgpu=<type>
PULL_CONFIG_AMDGPU="release"

# AMDGPU version (for release) or build number (for custom config)
# Arg: pullamdgpuver=<version|buildnum>
PULL_CONFIG_AMDGPU_BUILDNUM="31.10"

# AMDGPU mode: all (all distros) or single (current distro)
# Arg: amdgpu-mode=<all|single>
SETUP_AMDGPU_MODE="all"

# ROCm mode: native (use current OS) or chroot (use Ubuntu chroot)
# Arg: rocm-mode=<native|chroot>
SETUP_ROCM_MODE="chroot"

# Setup control flags (set via 'rocm' or 'amdgpu' args)
# Args: rocm, amdgpu
# Leave at 0 - script will auto-enable both if neither specified
SETUP_ROCM=0
SETUP_AMDGPU=0

#==============================================================================
# BUILD CONFIGURATION (build-installer.sh)
#==============================================================================

# Compression mode: hybrid, hybridmix, hybriddev, devsmall, devmedium, dev, normal
# Arg: mscomp=<mode>
MAKESELF_COMPRESS_MODE="hybrid"

# Build tag (used in installer name)
# Arg: buildtag=<tag>
BUILD_TAG="release"

# Build run ID
# Arg: buildrunid=<id>
BUILD_RUNID="99999"

# Build tag info (constructed from pulltag-pullrunid)
# Arg: buildtaginfo=<tag>
# Note: Typically PULL_CONFIG_TAG-PULL_CONFIG_RUNID
BUILD_TAG_INFO="release-99999"

# Enable/disable features
# Args: noextract, norocm, noamdgpu, norunfile, nogui
BUILD_EXTRACT="yes"      # Set to "no" via: noextract
BUILD_INSTALLER="yes"    # Set to "no" via: norunfile
BUILD_UI="yes"           # Set to "no" via: nogui
EXTRACT_ROCM="yes"       # Set to "no" via: norocm
EXTRACT_AMDGPU="yes"     # Set to "no" via: noamdgpu

# Extract type (optional)
# Args: noextractcontent, contentlist
EXTRACT_TYPE=""          # Set to "nocontent" via: noextractcontent
                         # Set to "contentlist" via: contentlist
